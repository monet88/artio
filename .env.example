# =============================================================================
# ARTIO - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git repository!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Required)
# Get from: Supabase Dashboard > Settings > API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ⚠️  SERVER-SIDE KEYS — DO NOT ADD TO .env.production (bundled in APK).
# Set via Supabase secrets: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<key>
# SUPABASE_SERVICE_ROLE_KEY bypasses ALL RLS — server-side only, never in client bundle.

# -----------------------------------------------------------------------------
# AI IMAGE GENERATION (Required for Edge Function)
# -----------------------------------------------------------------------------

# ⚠️  GEMINI_API_KEY and KIE_API_KEY are read by Supabase edge functions, NOT the Flutter client.
# Do NOT add to .env.production — set via: supabase secrets set GEMINI_API_KEY=<key> KIE_API_KEY=<key>
# Gemini API: https://aistudio.google.com/apikey | KIE API: https://kie.ai/api-key

# -----------------------------------------------------------------------------
# MONETIZATION (Optional - for Plan 2)
# -----------------------------------------------------------------------------

# RevenueCat
# Get from: https://app.revenuecat.com > Project Settings > API Keys
REVENUECAT_APPLE_KEY=your_revenuecat_apple_key
REVENUECAT_GOOGLE_KEY=your_revenuecat_google_key
REVENUECAT_WEB_KEY=your_revenuecat_web_key

# Stripe (Web payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# -----------------------------------------------------------------------------
# ADVERTISING (Optional)
# -----------------------------------------------------------------------------

# AdMob
# Get from: https://admob.google.com
ADMOB_ANDROID_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
ADMOB_IOS_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy

# =============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# =============================================================================
# Run these commands to set secrets for Edge Functions:
#
# supabase secrets set GEMINI_API_KEY=your_gemini_api_key
# supabase secrets set KIE_API_KEY=your_kie_api_key
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
# Verify with: supabase secrets list
# =============================================================================
